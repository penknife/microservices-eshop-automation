{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5433;Database=payments;Username=postgres;Password=postgres"
  },
  "Kafka": {
    "BootstrapServers": "localhost:29092",
    "ConsumerGroupId": "payment-service",
    "OutboxPollingIntervalSeconds": 2,
    "OutboxBatchSize": 50
  },
  "Payment": {
    "FailureThreshold": 999999.99
  },
  "Database": {
    "AutoMigrate": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
